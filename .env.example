# [FRONTEND NEXT.JS]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# [BACKEND LARAVEL]
APP_NAME="IRON LUNG API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# [DATABASE POSTGRESQL]
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ironlung_db
DB_USERNAME=postgres
DB_PASSWORD=

# [JWT AUTHENTICATION]
JWT_SECRET=

# [CLOUDINARY STORAGE]
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# [EMAIL NOTIFICATION]
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@ironlung.ac.id"
MAIL_FROM_NAME="${APP_NAME}"
